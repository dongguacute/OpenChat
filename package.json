{
  "name": "openchat",
  "private": true,
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "lint": "eslint .",
    "supabase": "cd packages/supabase && ./node_modules/.bin/supabase",
    "db:start": "pnpm -C packages/supabase start",
    "db:stop": "pnpm -C packages/supabase run stop",
    "db:status": "pnpm -C packages/supabase run status",
    "db:reset": "pnpm -C packages/supabase run reset"
  },
  "devDependencies": {
    "@eslint/js": "^9.19.0",
    "eslint": "^9.19.0",
    "eslint-plugin-react": "^7.37.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.18",
    "globals": "^15.14.0",
    "turbo": "^2.4.4",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.22.0"
  },
  "engines": {
    "node": ">=20"
  }
}
