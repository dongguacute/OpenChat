{
  "installCommand": "pnpm install",
  "buildCommand": "pnpm exec turbo run build",
  "outputDirectory": "apps/web/dist",
  "rewrites": [{ "source": "/((?!api/).*)", "destination": "/index.html" }],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
